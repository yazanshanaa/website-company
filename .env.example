PORT=3000
NODE_ENV=production

# ─── MongoDB ──────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<pass>@cluster.mongodb.net/?retryWrites=true&w=majority

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: node -e "const b=require('bcryptjs');b.hash('YOUR_PASSWORD',10).then(console.log)"
ADMIN_PASS_HASH=$2b$10$...

# Must be at least 32 random characters
SESSION_SECRET=replace-with-64-char-random-string

# ─── Email / SMTP ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=your-gmail@gmail.com

# ─── Proxy ────────────────────────────────────────────────────────────────────
# Set to true on Vercel / behind a reverse proxy so IP rate-limiting works correctly
BEHIND_PROXY=true
