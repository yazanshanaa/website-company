# âââ Required âââââââââââââââââââââââââââââââââââââââââââââââââââââââââââââââââ

# Random secret string â¥ 32 characters for signing session cookies
SESSION_SECRET=change_me_to_a_long_random_string_here

# âââ Admin password âââââââââââââââââââââââââââââââââââââââââââââââââââââââââââ
# Pre-computed bcrypt hash of the admin password.
# Generate with: node -e "require('bcryptjs').hash('YourPassword',10).then(console.log)"
# Required on Vercel (filesystem is read-only so password.txt cannot be used).
ADMIN_PASS_HASH=

# âââ Database (required for Vercel / any read-only filesystem deployment) âââââ
# MongoDB Atlas connection string â free M0 tier at https://www.mongodb.com/atlas
# Required on Vercel (read-only filesystem). Without it, all admin saves fail.
# Neon (PostgreSQL) — free tier at https://neon.tech. Adding Neon via the Vercel
# Marketplace injects DATABASE_URL automatically.
# Example: postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/db?sslmode=require
DATABASE_URL=

# âââ Email (contact form) âââââââââââââââââââââââââââââââââââââââââââââââââââââ
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASS=your_smtp_password
SMTP_FROM=noreply@example.com

# âââ Deployment âââââââââââââââââââââââââââââââââââââââââââââââââââââââââââââââ
NODE_ENV=production
# Set to "true" if running behind Nginx or a reverse proxy
BEHIND_PROXY=false
